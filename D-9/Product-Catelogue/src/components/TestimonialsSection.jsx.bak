          border-radius: var(--radius-md);
          text-align: center;
          transition: all 0.3s ease;
        }

        .stat-card:hover {
          border-color: var(--c-gold);
          transform: translateY(-5px);
          box-shadow: 0 15px 35px rgba(245, 158, 11, 0.2);
        }

        .stat-icon {
