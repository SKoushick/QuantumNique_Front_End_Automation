        .nav-btn {
          width: 50px;
          height: 50px;
          border-radius: 50%;
          background: var(--c-gold);
          color: white;
          border: none;
          cursor: pointer;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 20px;
          transition: all 0.3s ease;
          pointer-events: all;
        }

        .nav-btn:hover {
          transform: scale(1.1);
          box-shadow: 0 10px 25px rgba(245, 158, 11, 0.4);
        }

        .cta-banner {
          margin-top: 60px;
